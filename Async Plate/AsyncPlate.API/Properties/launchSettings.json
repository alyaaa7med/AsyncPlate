{
  "profiles": {
    "AsyncPlate.API": {
      "commandName": "Project",
      "launchBrowser": true,
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "applicationUrl": "https://localhost:51499;http://localhost:51500"
    }
  }
}